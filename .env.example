PORT=3006
MONGO_CONNECTION_URL=mongodb://localhost:27017/mtac
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
ALLOWED_ORIGINS=http://localhost:5173
REDIS_REST_URL=your_redis_url
REDIS_REST_TOKEN=your_redis_token

# Frontend URL (used in email links)
APP_URL=http://localhost:5173

# Email — choose "resend" or "smtp"
EMAIL_PROVIDER=resend
EMAIL_FROM=Onboarding <onboarding@resend.dev>

# Resend (EMAIL_PROVIDER=resend)
RESEND_API_KEY=your_resend_api_key

# SMTP (EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3006/api/auth/google/callback
